# ==============================================================================
# Environment Configuration Template (AD & Printer Onboarding Sync System)
# Copy this file to '.env' and populate with actual credentials before deployment.
# ==============================================================================

# --- FastAPI Gateway settings ---
HOST=0.0.0.0
PORT=8000
DEBUG_MODE=false

# --- Active Directory (LDAP) Configuration ---
# AD_AUTH_METHOD: "simple" (password) or "kerberos" (keytab)
AD_AUTH_METHOD=simple
# AD_HOSTS: Comma-separated list of Domain Controller IPs/hosts (For kerberos, MUST use FQDN e.g. "dc01.aapico.com")
AD_HOSTS=
AD_USER=
AD_PASSWORD=
KRB5_PRINCIPAL=svc-admin-it@AAPICO.COM
KRB5_KEYTAB=/etc/security/keytabs/HTTP.keytab
AD_BASE_DN=DC=aapico,DC=com
AD_NEW_HIRE_OU=OU=newhire,OU=Users,DC=aapico,DC=com
AD_CONTRACT_OU=OU=contract,OU=Users,DC=aapico,DC=com
VITE_TARGET_OU="OU=New_employee,DC=aapico,DC=com"

# --- Papercut Print Server API Configuration (XML-RPC) ---
# PAPERCUT_API_URL: Papercut URL endpoint (e.g. "http://10.10.10.235:9191/rpc/api/xmlrpc")
PAPERCUT_API_URL=
PAPERCUT_API_KEY=

# --- Microsoft Graph API Credentials (for M365 Licenses query) ---
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
# M365_DELAY_SECONDS=300

# --- Queue & SQLite Database Config ---
# For Docker deployments, use container service names:
REDIS_URL=redis://redis:6379/0
REDIS_MODE=live

# DB_PATH: SQLite database storage path inside container (mapped via volume)
DB_PATH=/app/data/jobs.db
JOB_LOG_RETENTION_DAYS=30
JOB_CANCEL_ROLLBACK_AD=true

# --- Mock Mode (for Sandbox / Debugging) ---
# If REDIS_MODE=mock, the system will use an in-memory/file-based mock queue
MOCK_REDIS_TYPE=temp
MOCK_REDIS_PATH=/app/data/redis_state.json
